# Configuration exemple pour le système vocal conversationnel
# Copiez ces lignes dans votre fichier .env et remplacez les valeurs

# OpenAI API - Utilisé pour Whisper (Speech-to-Text)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gemini API - Utilisé comme moteur de réponse principal si configuré
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-2.0-flash

# Anthropic Claude API - Utilisé pour générer les réponses
# https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ElevenLabs API - Utilisé pour Text-to-Speech
# https://elevenlabs.io/
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optionnel: ID de la voix ElevenLabs
# Par défaut: 21m00Tcm4TlvDq8ikWAM (Rachel)
# Consultez https://elevenlabs.io/voice-lab pour voir les autres voix
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
